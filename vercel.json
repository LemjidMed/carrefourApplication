{
  "buildCommand": "npm run web:build",
  "outputDirectory": "web/dist",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/mcp/:path*",
      "destination": "/api/mcp/:path*"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
